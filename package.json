{
  "name": "ocr-web-app",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:paddleocr": "services\\ocr\\paddleocr-service\\.venv\\Scripts\\python -m uvicorn --app-dir services/ocr/paddleocr-service main:app --host 0.0.0.0 --port 8000",
    "smoke:paddleocr": "services\\ocr\\paddleocr-service\\.venv\\Scripts\\python services\\ocr\\paddleocr-service\\smoke_test.py",
    "dev:supertone": "SUPERTONE_USE_GPU=true LD_LIBRARY_PATH=/home/cbandy/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH services/tts/supertone-service/.venv/bin/python -m uvicorn --app-dir services/tts/supertone-service main:app --host 0.0.0.0 --port 8100",
    "smoke:supertone": "services/tts/supertone-service/.venv/bin/python services/tts/supertone-service/smoke_test.py",
    "dev:kokoro": "KOKORO_USE_GPU=true LD_LIBRARY_PATH=/home/cbandy/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH services/tts/kokoro-service/.venv/bin/python -m uvicorn --app-dir services/tts/kokoro-service main:app --host 0.0.0.0 --port 8200",
    "smoke:kokoro": "curl -s http://localhost:8200/health | python3 -m json.tool",
    "dev:qwen": "QWEN_TTS_REQUIRE_GPU=true QWEN_TTS_HSA_OVERRIDE_GFX_VERSION=11.0.0 QWEN_TTS_ATTN_IMPLEMENTATION=eager LD_LIBRARY_PATH=/home/cbandy/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH services/tts/qwen-service/.venv/bin/python -m uvicorn --app-dir services/tts/qwen-service main:app --host 0.0.0.0 --port 8300",
    "smoke:qwen": "services/tts/qwen-service/.venv/bin/python services/tts/qwen-service/smoke_test.py",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build": "npm run build:frontend && npm run build:backend",
    "start:prod": "node backend/dist/main.js"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
