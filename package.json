{
  "name": "ocr-web-app",
  "version": "0.1.0-alpha.1",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "bootstrap:js": "bash scripts/linux/bootstrap-js-tooling.sh",
    "dev:backend": "bash scripts/linux/run-js-command.sh npm run start:dev --workspace=backend",
    "dev:frontend": "bash scripts/linux/run-js-command.sh npm run dev --workspace=frontend",
    "dev:paddleocr": "services/ocr/paddleocr-service/.venv/bin/python -m uvicorn --app-dir services/ocr/paddleocr-service main:app --host 0.0.0.0 --port 8000",
    "smoke:paddleocr": "services/ocr/paddleocr-service/.venv/bin/python services/ocr/paddleocr-service/smoke_test.py",
    "dev:supertone": "SUPERTONE_USE_GPU=true LD_LIBRARY_PATH=/home/cbandy/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH services/tts/supertone-service/.venv/bin/python -m uvicorn --app-dir services/tts/supertone-service main:app --host 0.0.0.0 --port 8100",
    "smoke:supertone": "services/tts/supertone-service/.venv/bin/python services/tts/supertone-service/smoke_test.py",
    "dev:kokoro": "KOKORO_USE_GPU=true LD_LIBRARY_PATH=/home/cbandy/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH services/tts/kokoro-service/.venv/bin/python -m uvicorn --app-dir services/tts/kokoro-service main:app --host 0.0.0.0 --port 8200",
    "smoke:kokoro": "services/tts/kokoro-service/.venv/bin/python services/tts/kokoro-service/smoke_test.py",
    "dev:f5": "HSA_OVERRIDE_GFX_VERSION=11.0.0 F5_TTS_REQUIRE_GPU=true LD_LIBRARY_PATH=/home/cbandy/.local/lib/python3.12/site-packages/torch/lib:$LD_LIBRARY_PATH services/tts/f5-service/.venv/bin/python -m uvicorn --app-dir services/tts/f5-service main:app --host 0.0.0.0 --port 8300",
    "smoke:f5": "services/tts/f5-service/.venv/bin/python services/tts/f5-service/smoke_test.py",
    "smoke:lmstudio": "bash scripts/linux/run-js-command.sh npm run test:smoke:lmstudio --workspace=backend",
    "smoke:all": "npm run smoke:paddleocr && npm run smoke:supertone && npm run smoke:kokoro && npm run smoke:f5",
    "build:frontend": "bash scripts/linux/run-js-command.sh npm run build --workspace=frontend",
    "build:backend": "bash scripts/linux/run-js-command.sh npm run build --workspace=backend",
    "build": "bash scripts/linux/run-js-command.sh npm run build:frontend && bash scripts/linux/run-js-command.sh npm run build:backend",
    "test:frontend": "bash scripts/linux/run-js-command.sh npm test --workspace=frontend",
    "test:backend": "bash scripts/linux/run-js-command.sh npm test --workspace=backend",
    "test:cov:frontend": "bash scripts/linux/run-js-command.sh npm run test:cov --workspace=frontend",
    "test:cov:backend": "bash scripts/linux/run-js-command.sh npm run test:cov --workspace=backend",
    "test:cov": "bash scripts/linux/run-js-command.sh npm run test:cov --workspace=frontend && bash scripts/linux/run-js-command.sh npm run test:cov --workspace=backend",
    "test:e2e:api": "bash scripts/linux/run-js-command.sh npm run test:e2e:api --workspace=backend",
    "test:e2e:integration": "bash scripts/linux/run-js-command.sh npm run test:e2e:integration --workspace=backend",
    "test:e2e:launcher": "bash scripts/linux/run-js-command.sh node --test e2e/ocr-launcher.e2e.mjs",
    "test:e2e:browser": "bash scripts/e2e/prepare-browser-env.sh && bash scripts/linux/run-js-command.sh npx playwright test",
    "perf:api": "bash scripts/linux/run-js-command.sh node scripts/perf/api-benchmark.mjs",
    "perf:browser": "bash scripts/linux/run-js-command.sh node scripts/perf/browser-benchmark.mjs",
    "perf:phase4": "bash scripts/perf/run-phase4.sh",
    "start:prod": "bash scripts/linux/run-js-command.sh node backend/dist/main.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
