{
  "name": "backend",
  "version": "0.1.0-alpha.1",
  "private": true,
  "scripts": {
    "build": "nest build gateway && nest build svc-ocr && nest build svc-tts && nest build svc-doc && nest build svc-vocab && nest build svc-agentic",
    "start": "nest start gateway",
    "start:dev": "nest start gateway --watch",
    "start:prod": "node dist/gateway/main.js",
    "start:prod:gateway": "node dist/gateway/main.js",
    "start:prod:svc-ocr": "node dist/services/ocr/src/main.js",
    "start:prod:svc-tts": "node dist/services/tts/src/main.js",
    "start:prod:svc-doc": "node dist/services/document/src/main.js",
    "start:prod:svc-vocab": "node dist/services/vocabulary/src/main.js",
    "start:prod:svc-agentic": "node dist/services/agentic/src/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:smoke:lmstudio": "jest --config jest.config.js --runInBand src/integration.spec.ts -t \"Integration: LM Studio structuring\"",
    "test:e2e:api": "jest --config jest.config.js --runInBand src/*.e2e.spec.ts",
    "test:e2e:integration": "jest --config jest.config.js --runInBand src/integration.spec.ts",
    "test:e2e": "npm run test:e2e:api && npm run test:e2e:integration",
    "test:e2e:image": "jest --config jest.config.js --runInBand src/app.e2e.spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "^6.5.0",
    "@openai/agents": "^0.7.2",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.32.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "undici": "^7.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
